# Скопируйте в .env для локальной разработки
VITE_API_URL=http://localhost:5000/api
VITE_API_ORIGIN=http://localhost:5000
VITE_SIGNALR_URL=http://localhost:5000/supportChat

# Production (сервер 89.108.66.220) — используется при npm run build:prod
# VITE_API_URL=http://89.108.66.220:5000/api
# VITE_API_ORIGIN=http://89.108.66.220:5000
# VITE_SIGNALR_URL=http://89.108.66.220:5000/supportChat

